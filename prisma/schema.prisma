// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  passwordResetTokens  PasswordResetToken[]
  quranProgress        UserQuranProgress?
  moduleProgresses     UserModuleProgress[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model UserQuranProgress {
  id          String   @id @default(uuid())
  surahNumber Int
  ayahNumber  Int
  updatedAt   DateTime @updatedAt

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_quran_progress")
}

model ModuleCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  modules     Module[]

  @@map("module_categories")
}

model Module {
  id         String   @id @default(uuid())
  title      String
  content    String   @db.Text

  categoryId String
  category   ModuleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userProgresses UserModuleProgress[]

  @@map("modules")
}

model UserModuleProgress {
  id          String    @id @default(uuid())
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  moduleId    String
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("user_module_progress")
}
